rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admins ─────────────────────────────────────────────
    // Lectura permitida a cualquier sesión autenticada: la app verifica el
    // rol con un query por `email` (el doc tiene ID autogenerado, no el uid),
    // así que no se puede restringir por uid. El contenido es solo nombre+email
    // y leerlo NO otorga privilegios (el privilegio se valida por email tras
    // autenticar con Google/email en Firebase Auth).
    // La escritura se hace manualmente desde la consola de Firebase.
    match /super_admins/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // El super admin se identifica por su email verificado de Firebase Auth
    // (Google/email). No se puede consultar la colección super_admins desde las
    // reglas (solo lookups por ID, y el doc tiene ID autogenerado), así que se
    // listan aquí los correos autorizados. Agregar más si hay más super admins.
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'johandavidromoro@gmail.com'
        ];
    }

    // Cualquier sesión de Firebase Auth, incluida la ANÓNIMA que la app
    // inicia automáticamente al arrancar. Bloquea el acceso de quien no
    // pase por la app (sin token = denegado).
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Restaurantes ─────────────────────────────────────────────
    // Lectura: requiere sesión (la app inicia una anónima antes del login,
    // así que la pantalla de selección sigue funcionando).
    // Crear / suspender / editar un restaurante: solo el super admin.
    match /restaurants/{restaurantId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();

      // ── Datos operativos de cada restaurante ───────────────────
      // users, products, tables, orders, order_history, expenses.
      //
      // ⚠️ LIMITACIÓN CONOCIDA (aislamiento entre restaurantes):
      // Los empleados se autentican por PIN (no Firebase Auth), por lo que
      // todos comparten una sesión anónima sin saber a qué restaurante
      // pertenecen. Exigir sesión cierra el acceso totalmente abierto, pero
      // NO aísla un restaurante de otro a nivel de servidor. El aislamiento
      // real requiere Firebase Auth con custom claims (Cloud Functions / Blaze).
      match /{subcollection}/{docId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
