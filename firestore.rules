rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admins ─────────────────────────────────────────────
    // Solo el propio super admin (autenticado con Firebase Auth) puede leer
    // su documento. La escritura se hace manualmente desde la consola de Firebase.
    match /super_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/super_admins/$(request.auth.uid));
    }

    // ── Restaurantes ─────────────────────────────────────────────
    // Lectura pública: la pantalla de login necesita listar restaurantes
    // (los empleados aún NO usan Firebase Auth, son anónimos para Firestore).
    // Crear / suspender / editar un restaurante: solo el super admin.
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();

      // ── Datos operativos de cada restaurante ───────────────────
      // users, products, tables, orders, order_history, expenses.
      //
      // ⚠️ LIMITACIÓN DE SEGURIDAD CONOCIDA:
      // Los empleados se autentican por PIN (no Firebase Auth), por lo que
      // request.auth es null y NO se puede aislar el tenant a nivel de servidor.
      // Hoy el aislamiento lo garantiza el cliente (TenantService).
      // Para seguridad real por restaurante hace falta migrar a Firebase Auth
      // con custom claims (requiere Cloud Functions). Ver Fase de endurecimiento.
      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
